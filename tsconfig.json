{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "declaration": false,
    "declarationMap": false
  },
  "include": [
    "packages/*/src/**/*.ts",
    "web/src/**/*.ts",
    "plugins/**/*.ts"
  ],
  "exclude": [
    "**/__tests__/**",
    "node_modules",
    "dist",
    "target"
  ]
}
